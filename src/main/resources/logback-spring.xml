<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <conversionRule conversionWord="piiMask"
                    converterClass="com.bank.sentinel.infrastructure.logging.PiiMaskingConverter"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %piiMask%n</pattern>
        </encoder>
    </appender>

    <logger name="com.bank.sentinel" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
